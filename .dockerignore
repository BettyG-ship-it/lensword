# Virtual environments — both naming conventions
.venv/
venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Git
.git/
.gitignore

# Notebooks — not needed in container
notebooks/
*.ipynb
*.ipynb_checkpoints

# Reports and screenshots — not needed in container
reports/
screenshots/

# Data — large files not needed in container
data/

# Only copy the one model checkpoint used
models/*.png
models/*.csv
models/lensword_model_*.pt

# Development files
.env
*.log
